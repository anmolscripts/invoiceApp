<%- include("partials/layout-start", { title: "Dashboard", bodyClass: "list-page" }) %>

<main class="shell">
  <section class="hero-panel">
    <div class="row g-4 align-items-end">
      <div class="col-lg-8">
        <span class="eyebrow"><i class="bi bi-speedometer2"></i> Business Dashboard</span>
        <h1>One place to track clients, projects, billing, and finance activity.</h1>
        <p>See active work, upcoming billing-cycle reminders, and the most recent invoices without jumping between modules.</p>
      </div>
      <div class="col-lg-4">
        <div class="brand-card text-center mb-3">
          <img src="/img/logo.svg" alt="Logo" class="img-fluid mx-auto d-block" />
          <p class="mt-3 mb-0">Operations, billing, settlement, and finance in one branded control room.</p>
        </div>
        <div class="hero-actions">
          <% if (canCreate) { %>
          <a class="hero-btn primary" href="/add"><i class="bi bi-plus-circle-fill"></i> New Invoice</a>
          <% } %>
          <a class="hero-btn secondary" href="/invoices"><i class="bi bi-receipt"></i> Invoice Register</a>
          <a class="hero-btn secondary" href="/history"><i class="bi bi-clock-history"></i> History</a>
          <% if (canEdit) { %>
          <a class="hero-btn secondary" href="/settlements"><i class="bi bi-wallet2"></i> Settlements</a>
          <% } %>
          <a class="hero-btn secondary" href="/finance"><i class="bi bi-graph-up-arrow"></i> Finance</a>
          <% if ((currentUser?.role || "").toLowerCase() === "admin") { %>
          <a class="hero-btn secondary" href="/users"><i class="bi bi-person-badge-fill"></i> Users</a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="summary-grid">
      <article class="summary-card"><div class="summary-label"><span>Clients</span><span class="summary-icon"><i class="bi bi-buildings"></i></span></div><h2 class="text-secondary"><%= stats.totalClients %></h2><p>Total active clients.</p></article>
      <article class="summary-card"><div class="summary-label"><span>Projects</span><span class="summary-icon"><i class="bi bi-kanban"></i></span></div><h2 class="text-secondary"><%= stats.totalProjects %></h2><p>Total active projects.</p></article>
      <article class="summary-card"><div class="summary-label"><span>Invoices</span><span class="summary-icon"><i class="bi bi-receipt-cutoff"></i></span></div><h2 class="text-secondary"><%= stats.totalInvoices %></h2><p>Invoice count in the system.</p></article>
      <article class="summary-card"><div class="summary-label"><span>Total Business</span><span class="summary-icon"><i class="bi bi-cash-stack"></i></span></div><h2 class="text-secondary">&#8377; <%= rateConvert(Number(stats.totalBusiness || 0).toFixed(2)) %></h2><p>Combined value of all records.</p></article>
    </div>
  </section>

  <section class="board">
    <div class="detail-grid mb-4">
      <section class="detail-card chart-card">
        <h4>Business Mix</h4>
        <div class="chart-wrap">
          <canvas id="mixChart"></canvas>
        </div>
      </section>
      <section class="detail-card chart-card">
        <h4>Operational Snapshot</h4>
        <div class="chart-wrap">
          <canvas id="opsChart"></canvas>
        </div>
      </section>
    </div>

    <div class="detail-grid">
      <section class="detail-card">
        <h4>Billing Cycle Due</h4>
        <% if (dueProjects.length) { %>
        <div class="item-stack">
          <% dueProjects.forEach((project) => { %>
          <div class="item-line">
            <div>
              <strong><%= project.project_name %></strong>
              <small><%= project.client?.client_name || "-" %> | <%= project.billing_cycle_type || "-" %> | <%= project.billing_due_date ? formatDate(project.billing_due_date) : "-" %></small>
            </div>
            <a class="action-btn view" href="/add">Create Invoice</a>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="m-0 text-muted">No billing cycles are due right now.</p>
        <% } %>
      </section>

      <section class="detail-card">
        <h4>Recent Invoices</h4>
        <% if (invoices.length) { %>
        <div class="item-stack">
          <% invoices.forEach((invoice) => { %>
          <div class="item-line">
            <div>
              <strong><%= invoice.invoice_number %></strong>
              <small><%= invoice.project?.project_name || invoice.client_name %> | <%= formatDate(invoice.invoice_date) %></small>
            </div>
            <strong>&#8377; <%= rateConvert(Number(invoice.grand_total || 0).toFixed(2)) %></strong>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="m-0 text-muted">No invoices available yet.</p>
        <% } %>
      </section>
    </div>

    <div class="detail-grid mt-4">
      <section class="detail-card">
        <h4>Active Clients</h4>
        <% if (clients.length) { %>
        <div class="item-stack">
          <% clients.forEach((client) => { %>
          <div class="item-line">
            <div>
              <strong><%= client.client_name %></strong>
              <small><%= client.client_no || client.client_code %> | <%= client._count.projects %> projects | <%= client._count.invoices %> records</small>
            </div>
            <a class="action-btn view" href="/clients/<%= client.client_id %>">Open</a>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="m-0 text-muted">No clients created yet.</p>
        <% } %>
      </section>

      <section class="detail-card">
        <h4>Active Projects</h4>
        <% if (projects.length) { %>
        <div class="item-stack">
          <% projects.forEach((project) => { %>
          <div class="item-line">
            <div>
              <strong><%= project.project_name %></strong>
              <small><%= project.project_no || project.project_code %> | <%= project.client?.client_name || "-" %> | <%= project._count.invoices %> records</small>
            </div>
            <a class="action-btn view" href="/projects/<%= project.project_id %>">Open</a>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="m-0 text-muted">No projects created yet.</p>
        <% } %>
      </section>
    </div>
  </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  (() => {
    const mixCanvas = document.getElementById("mixChart");
    const opsCanvas = document.getElementById("opsChart");
    if (!mixCanvas || !opsCanvas || !window.Chart) return;

    new Chart(mixCanvas, {
      type: "doughnut",
      data: {
        labels: ["Clients", "Projects", "Invoices", "Quotations"],
        datasets: [{
          data: [<%= stats.totalClients %>, <%= stats.totalProjects %>, <%= stats.totalInvoices %>, <%= stats.totalQuotations %>],
          backgroundColor: ["#123458", "#f9cc0a", "#12715f", "#4c3bb8"],
          borderWidth: 0,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: "bottom",
          },
        },
      },
    });

    new Chart(opsCanvas, {
      type: "bar",
      data: {
        labels: ["Billing Due", "Recent Invoices", "Active Clients", "Active Projects"],
        datasets: [{
          label: "Count",
          data: [<%= dueProjects.length %>, <%= invoices.length %>, <%= clients.length %>, <%= projects.length %>],
          backgroundColor: ["#f9cc0a", "#123458", "#12715f", "#4c3bb8"],
          borderRadius: 14,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 },
          },
        },
        plugins: {
          legend: {
            display: false,
          },
        },
      },
    });
  })();
</script>

<%- include("partials/layout-end") %>
