<%- include("../partials/layout-start", { title: "Set Password", bodyClass: "login-page" }) %>

<main class="login-shell">
  <section class="login-brand">
    <span class="eyebrow"><i class="bi bi-key-fill"></i> Account Activation</span>
    <img src="/img/logo.svg" alt="Logo" />
    <h1>Set your password to activate your workspace access.</h1>
    <p>Your user ID is <strong><%= user?.user_code || "-" %></strong>. After setting your password, you can sign in to the modules assigned to you.</p>
  </section>

  <section class="login-panel">
    <div class="login-card">
      <h2>Set Password</h2>
      <% if (error) { %><div class="alert alert-custom"><%= error %></div><% } %>
      <form method="post" action="/setup-password/<%= token %>">
        <div class="field">
          <label>Password</label>
          <input class="form-control" name="password" type="password" required />
        </div>
        <div class="field">
          <label>Verify Password</label>
          <input class="form-control" name="confirm_password" type="password" required />
        </div>
        <button type="submit" class="btn-login">Save Password</button>
      </form>
    </div>
  </section>
</main>

<%- include("../partials/layout-end") %>
