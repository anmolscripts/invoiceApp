<%- include("partials/layout-start", { title: "User Login", bodyClass: "login-page" }) %>

<main class="login-shell">
  <section class="login-brand">
    <span class="eyebrow"><i class="bi bi-shield-lock-fill"></i> Secure User Access</span>
    <img src="/img/logo.svg" alt="Logo" />
    <h1>Sign in with your generated user ID to open the modules assigned to you.</h1>
    <p>Access is now role and module based. Admins can manage users, while editors and viewers only see the modules granted to them.</p>
    <div class="brand-rail">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </section>

  <section class="login-panel">
    <div class="login-card">
      <h2>User Login</h2>
      <p>Use your user ID and password to continue to the dashboard.</p>

      <% if (error) { %>
      <div class="alert alert-custom"><%= error %></div>
      <% } %>

      <form action="/login" method="post">
        <div class="field">
          <label for="username">User ID</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
            <input id="username" name="username" type="text" class="form-control" placeholder="Enter user ID" required />
          </div>
        </div>

        <div class="field">
          <label for="password">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
            <input id="password" name="password" type="password" class="form-control" placeholder="Enter password" required />
          </div>
        </div>

        <button type="submit" class="btn-login">Login to Workspace</button>
      </form>

      <div class="hint-box">
        <strong>Default super admin:</strong> user ID `USER/2026/1` and password `admin`
      </div>
    </div>
  </section>
</main>

<%- include("partials/layout-end") %>
